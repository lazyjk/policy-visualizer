            <Attribute isUserAttr="false" isRole="false" attrDataType="String" aliasName="Other Device Name" attrName="other_name"/>
            <Attribute isUserAttr="false" isRole="false" attrDataType="Boolean" aliasName="Conflict" attrName="conflict"/>
          </Attributes>
        </Filter>
        <Filter paramValues="" filterQuery="SELECT fingerprint, CAST(fingerprint as jsonb)-&gt;'host'-&gt;&gt;'app_id' as app_id, CAST(fingerprint as jsonb)-&gt;'host'-&gt;&gt;'app_group' as app_group, CAST(fingerprint as jsonb)-&gt;'host'-&gt;&gt;'user_agent' as user_agent, CAST(fingerprint as jsonb)-&gt;'host'-&gt;&gt;'dst_conns' as dst_conns, CAST(fingerprint as jsonb)-&gt;'host'-&gt;&gt;'ports' as open_port,CAST(fingerprint as jsonb)-&gt;'nmap'-&gt;&gt;'device' as nmap_device_name, CAST(fingerprint as jsonb)-&gt;'nmap'-&gt;&gt;'os_family' as nmap_device_family, CAST(fingerprint as jsonb)-&gt;'nmap'-&gt;&gt;'os_type' as nmap_device_type, CAST(fingerprint as jsonb)-&gt;'nmap'-&gt;&gt;'os_vendor' as nmap_device_vendor, CAST(fingerprint as jsonb)-&gt;'nmap'-&gt;&gt;'os_gen' as nmap_device_os_version FROM tips_endpoint_profiles WHERE mac = LOWER('%{Connection:Client-Mac-Address-NoDelim}')" filterName="Fingerprint">
